# ============================================================
# NexusHub Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# JWT - Generate a strong secret: openssl rand -base64 64
JWT_SECRET=nexushub_jwt_secret_key_change_in_production_min_256_bits

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth2 (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (get from github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Database passwords (change in production)
POSTGRES_PASSWORD=nexushub_secret
MONGO_PASSWORD=nexushub_secret
REDIS_PASSWORD=nexushub_secret
MINIO_SECRET_KEY=nexushub_secret_minio
CLICKHOUSE_PASSWORD=nexushub_secret
